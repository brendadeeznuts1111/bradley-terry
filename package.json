{
  "name": "@platform/bradley-terry",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "start:example": "bun run examples/usage-complete.ts",
    "dev": "bun --watch src/server/index.ts",
    "test": "bun test",
    "ci": "bun test && bun run lint",
    "secret": "bun scripts/bun-secret.ts",
    "lint": "bunx @biomejs/biome check src tests scripts schema.ts",
    "lint:fix": "bunx @biomejs/biome check --write src tests scripts schema.ts"
  },
  "dependencies": {
    "effect": "3.21.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@types/bun": "1.3.14"
  }
}
