{
  "name": "bradley-terry",
  "description": "Bradley-Terry model for ranking entities based on pairwise comparisons",
  "version": "0.3.33",
  "type": "module",
  "packageManager": "bun@1.4.0",
  "scripts": {
    "start": "bun run src/server/index.ts",
    "start:example": "bun run examples/usage-complete.ts",
    "start:example:sqlite": "bun run examples/usage-sqlite.ts",
    "dev": "bun --watch src/server/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:matrix": "bun test test/completion-matrix.unit.test.ts",
    "test:snapshots:update": "bun test --update-snapshots",
    "ci": "bun test && bun run lint",
    "secret": "bun scripts/bun-secret.ts",
    "lint": "bunx @biomejs/biome check src tests test scripts",
    "lint:fix": "bunx @biomejs/biome check --write src tests test scripts",
    "bench": "bun run src/bench/bt-fit.bench.ts",
    "completions": "bun run scripts/generate-cli-completions.ts",
    "completions:bunfig": "bun run scripts/generate-bunfig-completions.ts",
    "completions:audit": "bun run scripts/audit-cli-flags.ts",
    "completions:audit:docs": "bun run scripts/audit-run-docs.ts",
    "completions:audit:upstream": "bun run scripts/audit-upstream-cli.ts",
    "completions:regen": "bun run completions && bun run completions:bunfig && bun run matrix && bun run completions:shell",
    "completions:shell": "bun run scripts/generate-shell-completions.ts",
    "matrix": "bun run scripts/make-completion-matrix.ts",
    "check:completions": "bun run scripts/check-completion-drift.ts",
    "check:fast": "bun run check:completions && bun run lint",
    "update-readme-test-counts": "bun run scripts/update-readme-test-counts.ts",
    "check:full": "bun run check:fast && bun run update-readme-test-counts && bun run bench"
  },
  "dependencies": {
    "effect": "3.21.4",
    "preact": "^10.29.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "fast-check": "4.8.0"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
