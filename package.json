{
	"name": "bradley-terry",
	"description": "Bradley-Terry model for ranking entities based on pairwise comparisons",
	"version": "0.3.32",
	"type": "module",
	"packageManager": "bun@1.4.0",
	"scripts": {
		"start": "bun run examples/usage-complete.ts",
		"dev": "bun --watch examples/usage-complete.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:matrix": "bun test test/completion-matrix.unit.test.ts",
		"test:snapshots:update": "bun test --update-snapshots",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --write .",
		"bench": "bun run src/bench/bt-fit.bench.ts",
		"completions": "bun run scripts/generate-cli-completions.ts",
		"completions:shell": "bun run scripts/generate-shell-completions.ts",
		"matrix": "bun run scripts/make-completion-matrix.ts",
		"check:completions": "bun run scripts/check-completion-drift.ts",
		"cookbook": "bun test test/bun-api/one-liners.test.ts",
		"check:fast": "bun run check:completions && bun run lint",
		"check:types": "tsc --noEmit 2>&1 | grep -v \"TS2339:\" | grep -v \"node_modules\" | grep -q \"^[a-z]\" && exit 1 || exit 0",
		"check:gates": "bun run check:types && bun test",
		"update-readme-test-counts": "bun run scripts/update-readme-test-counts.ts",
		"api-docs": "bun run scripts/api-docs.ts",
		"check:full": "bun run check:gates && bun run check:completions && bun run lint && bun run update-readme-test-counts && bun run bench"
	},
	"dependencies": {
		"effect": "3.21.4",
		"preact": "^10.29.2",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.6",
		"@types/bun": "^1.3.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"fast-check": "4.8.0",
		"typescript": "5.7.3"
	},
	"overrides": {
		"react": "19.2.0",
		"react-dom": "19.2.0"
	}
}
